###############################################################################
# FlClouds 环境配置文件模板 (Environment Configuration Template)
# 说明：请复制此文件为 .env 并根据实际部署环境进行修改
###############################################################################

# --- 数据库配置 (Database Settings) ---
# PostgreSQL 数据库密码 (必填)
DB_PASSWORD=your_secure_password_here

# --- 服务基础配置 (Service Settings) ---
# 后端服务运行端口 (默认: 51947)
PORT=51947
# 应用主域名 (用于各种链接生成，不带 http/https)
DOMAIN=cloud.example.com

# --- 存储配置 (Storage Settings) ---
# 文件上传保存根目录 (容器内路径)
UPLOAD_DIR=/data/uploads
# 缩略图生成目录 (容器内路径)
THUMBNAIL_DIR=/data/thumbnails
# 分片上传缓存目录 (容器内路径)
CHUNK_DIR=/data/chunks
# 是否按来源/频道/文件类型自动分层保存。开启后示例：telegram/频道名/images/file.jpg
STORAGE_CLASSIFY_BY_PATH=true
# 保存路径细分开关：按来源/频道、按文件类型
STORAGE_PATH_BY_SOURCE=true
STORAGE_PATH_BY_TYPE=true
# 重复文件策略：copy=生成副本，skip=跳过重复（同名+同目录+同大小）
DUPLICATE_FILE_MODE=copy
# 是否自动清理本地 uploads 中未登记到数据库的孤儿文件。默认开启，可在 Bot 里用 /cleanup_settings 关闭。
AUTO_CLEANUP_ORPHANS=true

# --- 网络与安全 (Network & Security) ---
# [重要] 前端访问后端的 API 地址 (需包含协议和端口)
# 反代建议：api.example.com -> 宿主机 51947 端口
VITE_API_URL=https://api.example.com

# [重要] 允许跨域的来源地址 (通常填前端网页的完整访问地址)
# 反代建议：cloud.example.com -> 宿主机 47832 端口
# 生产环境建议指定具体域名；若允许所有来源可填 *
CORS_ORIGIN=https://cloud.example.com

# [可选] 管理访问密码的哈希值 (使用 SHA-256 算法，生成方法见 README)
ACCESS_PASSWORD_HASH=

# --- 第三方集成 (Integrations) ---
# Telegram Bot 配置 (可选，用于大文件存储扩展)
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram 用户账号下载器（可选，用于账号级 MTProto 下载）
TELEGRAM_USER_API_ID=
TELEGRAM_USER_API_HASH=
TELEGRAM_USER_SESSION_FILE=/data/telegram_user_session.txt
# 可选：桥接群/频道 ID。配置后，私聊发给 bot 的文件会先转发到该聊天，
# 再由用户账号从桥接聊天下载。bot 和用户账号都必须能访问该聊天。
TELEGRAM_DOWNLOAD_BRIDGE_CHAT_ID=
# Telegram 并发下载 worker 数。单请求上限仍是 512KB；该值控制并发请求数，建议 4-8，最大 16。
TELEGRAM_DOWNLOAD_WORKERS=4

# yt-dlp 配置 (可选，用于 /ytdlp <url> 下载并上传到当前存储源)
# yt-dlp 可执行文件路径（默认: yt-dlp，使用系统 PATH；仅在找不到命令时再改为绝对路径）
YTDLP_BIN=yt-dlp
# yt-dlp 下载工作目录（默认: ./data/uploads/ytdlp）
YTDLP_WORK_DIR=./data/uploads/ytdlp
# yt-dlp 下载任务并发（默认: 1）
YTDLP_MAX_CONCURRENT=1

# Telegram Bot 限流：普通消息每分钟 30 次；重型命令（/ytdlp、/tg_date、/tg_tag、/cleanup_settings）每 10 分钟 5 次
TELEGRAM_RATE_WINDOW_MS=60000
TELEGRAM_RATE_MAX=30
TELEGRAM_HEAVY_RATE_WINDOW_MS=600000
TELEGRAM_HEAVY_RATE_MAX=5

# --- 安全与限流 ---
TRUST_PROXY=loopback
JSON_BODY_LIMIT=2mb
MAX_UPLOAD_CHUNK_MB=64
MAX_UPLOAD_SESSIONS=200
MAX_TOTAL_CHUNKS=50000
ORPHAN_CLEANUP_MIN_AGE_MS=600000
TG_STATUS_DEBUG_LOG=/data/logs/tg_silent_debug.log
TG_DEBUG_LOG_MAX_MB=5
